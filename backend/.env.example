# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL + PostGIS) ─────────────────────
DATABASE_URL=postgres://agrolink:agrolink@localhost:5432/agrolink360

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── MTN MoMo Collection API (sandbox by default) ────────
# Get sandbox credentials at https://momodeveloper.mtn.com
MOMO_ENV=sandbox
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_CALLBACK_URL=http://localhost:4000/api/payments/momo/callback

# ── Python AI microservice ──────────────────────────────
# If unset, the Node service falls back to built-in heuristics.
AI_SERVICE_URL=http://localhost:8000
